<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="TaskPaneApp">

  <!-- ★ 請將下方三個 YOUR_GITHUB_USERNAME 改成你自己的 GitHub 使用者名稱 -->
  <!-- ★ 並將 rtf-addin 改成你的 repository 名稱（如果不同的話） -->

  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>RTF 智能標記系統</ProviderName>
  <DefaultLocale>zh-TW</DefaultLocale>

  <DisplayName DefaultValue="RTF 智能標記" />
  <Description DefaultValue="自動偵測詞語並套用多層次標記格式，提升閱讀重點辨識度。" />

  <SupportUrl DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/rtf-addin/" />

  <Hosts>
    <Host Name="Document" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="WordApi" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://YOUR_GITHUB_USERNAME.github.io/rtf-addin/taskpane.html" />
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

</OfficeApp>
